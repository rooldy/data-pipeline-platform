# ============================================================================
# DAG AUTO-GÉNÉRÉ PAR DATA PIPELINE PLATFORM
# Pipeline : {{ pipeline.name }}
# Généré le : {{ generated_at }}
# NE PAS MODIFIER MANUELLEMENT
# ============================================================================

from datetime import datetime, timedelta
from airflow import DAG
from airflow.operators.python import PythonOperator
from airflow.operators.empty import EmptyOperator
import json
import logging

logger = logging.getLogger(__name__)

default_args = {
    "owner": "data-pipeline-platform",
    "depends_on_past": False,
    "email_on_failure": False,
    "email_on_retry": False,
    "retries": 1,
    "retry_delay": timedelta(minutes=5),
}

dag = DAG(
    dag_id="{{ dag_id }}",
    description="{{ description }}",
    default_args=default_args,
    schedule_interval={{ "'" + schedule + "'" if schedule else "None" }},
    start_date=datetime(2024, 1, 1),
    catchup=False,
    tags=["generated", "medallion"{% for node in nodes %}, "{{ node.layer.value }}"{% endfor %}],
)

# ── Fonctions des tâches ────────────────────────────────────────────────────

{% for node in nodes %}
def task_{{ node.id | replace('-', '_') }}(**context):
    """{{ node.kind.value | upper }} — {{ node.label }} ({{ node.subtype }})"""
    import sys
    sys.path.insert(0, '/opt/airflow/plugins')
    from spark_tasks import (
        get_spark_session, read_csv, read_postgresql,
        apply_filter, apply_aggregate, apply_join, apply_cast,
        write_delta_lake, write_postgresql,
        write_checkpoint, read_checkpoint
    )

    DAG_ID  = "{{ dag_id }}"
    NODE_ID = "{{ node.id | replace('-', '_') }}"
    config  = json.loads('{{ node_configs[node.id] | tojson }}')
    spark   = get_spark_session(f"{DAG_ID}_{NODE_ID}")

    {% if node.kind.value == 'source' %}
    # ── Source : {{ node.subtype }} ──
    {% if node.subtype == 'csv' %}
    df = read_csv(spark, config)
    {% elif node.subtype == 'postgresql' %}
    df = read_postgresql(spark, config)
    {% elif node.subtype == 'api_rest' %}
    import requests
    response = requests.request(
        method=config.get('method', 'GET'),
        url=config.get('url', ''),
        headers=config.get('headers', {}),
    )
    data = response.json()
    df = spark.createDataFrame(data if isinstance(data, list) else [data])
    {% elif node.subtype == 's3' %}
    path = f"s3a://{config.get('bucket')}/{config.get('prefix')}"
    df   = spark.read.format(config.get('file_format', 'parquet')).load(path)
    {% endif %}

    {% elif node.kind.value == 'transform' %}
    # ── Transformation : {{ node.subtype }} ──
    {% set parent_id = edges | selectattr('target', 'equalto', node.id) | map(attribute='source') | first | replace('-', '_') %}
    df = read_checkpoint(spark, DAG_ID, "{{ parent_id }}")
    {% if node.subtype == 'filter' %}
    df = apply_filter(df, config)
    {% elif node.subtype == 'aggregate' %}
    df = apply_aggregate(df, config)
    {% elif node.subtype == 'cast' %}
    df = apply_cast(df, config)
    {% elif node.subtype == 'join' %}
    {% set parents = edges | selectattr('target', 'equalto', node.id) | map(attribute='source') | list %}
    df_left  = read_checkpoint(spark, DAG_ID, "{{ parents[0] | replace('-', '_') }}")
    {% if parents | length > 1 %}
    df_right = read_checkpoint(spark, DAG_ID, "{{ parents[1] | replace('-', '_') }}")
    {% else %}
    df_right = df_left
    {% endif %}
    df = apply_join(df_left, df_right, config)
    {% endif %}

    {% elif node.kind.value == 'output' %}
    # ── Destination : {{ node.subtype }} ──
    {% set parent_id = edges | selectattr('target', 'equalto', node.id) | map(attribute='source') | first | replace('-', '_') %}
    df = read_checkpoint(spark, DAG_ID, "{{ parent_id }}")
    {% if node.subtype == 'delta_lake' %}
    write_delta_lake(df, config)
    {% elif node.subtype == 'postgresql' %}
    write_postgresql(df, config)
    {% endif %}
    spark.stop()
    return {"status": "success", "node": NODE_ID, "layer": "{{ node.layer.value }}"}
    {% endif %}

    # Sauvegarder le checkpoint pour les tâches suivantes
    {% if node.kind.value != 'output' %}
    row_count = df.count()
    write_checkpoint(df, DAG_ID, NODE_ID)
    context['ti'].xcom_push(key='row_count', value=row_count)
    spark.stop()
    return {"status": "success", "node": NODE_ID, "rows": row_count, "layer": "{{ node.layer.value }}"}
    {% endif %}

{% endfor %}

# ── Opérateurs ──────────────────────────────────────────────────────────────

start = EmptyOperator(task_id="start", dag=dag)
end   = EmptyOperator(task_id="end",   dag=dag)

{% for node in nodes %}
task_{{ node.id | replace('-', '_') }}_op = PythonOperator(
    task_id="{{ node.id | replace('-', '_') }}",
    python_callable=task_{{ node.id | replace('-', '_') }},
    dag=dag,
)
{% endfor %}

# ── Dépendances ─────────────────────────────────────────────────────────────

start >> [
{% for node in nodes %}
{% if not edges | selectattr('target', 'equalto', node.id) | list %}
    task_{{ node.id | replace('-', '_') }}_op,
{% endif %}
{% endfor %}
]

{% for edge in edges %}
task_{{ edge.source | replace('-', '_') }}_op >> task_{{ edge.target | replace('-', '_') }}_op
{% endfor %}

[
{% for node in nodes %}
{% if not edges | selectattr('source', 'equalto', node.id) | list %}
    task_{{ node.id | replace('-', '_') }}_op,
{% endif %}
{% endfor %}
] >> end